@page "/profile"
@using CinemaServer.DTOs
@using CinemaServer.WebServices
@inject CinemaApiService ApiService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>CINEMA ONLINE - Личный кабинет</PageTitle>

<!-- Hero Profile Section -->
<div class="hero-profile"></div>

<!-- Main Content -->
<div class="container" style="padding-top: 0; padding-bottom: 3rem;">
    @if (!_isAuthenticated)
    {
        <!-- Login/Register Forms -->
        <div style="margin-top: -8rem; position: relative; z-index: 10;">
            <div class="auth-form" style="max-width: 500px; margin: 0 auto;">
                <div style="display: flex; gap: 1rem; margin-bottom: 2rem;">
                    <button class="btn-primary" style="flex: 1; @(_isLoginMode ? "" : "background-color: rgba(179, 153, 159, 0.3); border-color: rgba(179, 153, 159, 0.3);")"
                            @onclick="() => _isLoginMode = true">
                        Вход
                    </button>
                    <button class="btn-primary" style="flex: 1; @(_isLoginMode ? "background-color: rgba(179, 153, 159, 0.3); border-color: rgba(179, 153, 159, 0.3);" : "")"
                            @onclick="() => _isLoginMode = false">
                        Регистрация
                    </button>
                </div>

                @if (_errorMessage != null)
                {
                    <div class="error-message">@_errorMessage</div>
                }

                @if (_isLoginMode)
                {
                    <EditForm Model="_loginModel" OnValidSubmit="HandleLogin">
                        <DataAnnotationsValidator />
                        
                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <InputText @bind-Value="_loginModel.Email" class="form-input" placeholder="email@example.com" />
                            <ValidationMessage For="() => _loginModel.Email" />
                        </div>

                        <div class="form-group">
                            <label class="form-label">Пароль</label>
                            <InputText @bind-Value="_loginModel.Password" type="password" class="form-input" placeholder="••••••••" />
                            <ValidationMessage For="() => _loginModel.Password" />
                        </div>

                        <button type="submit" class="btn-primary" style="width: 100%;" disabled="@_isSubmitting">
                            @(_isSubmitting ? "Вход..." : "Войти")
                        </button>
                    </EditForm>
                }
                else
                {
                    <EditForm Model="_registerModel" OnValidSubmit="HandleRegister">
                        <DataAnnotationsValidator />
                        
                        <div class="form-group">
                            <label class="form-label">Имя</label>
                            <InputText @bind-Value="_registerModel.Name" class="form-input" placeholder="Ваше имя" />
                            <ValidationMessage For="() => _registerModel.Name" />
                        </div>

                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <InputText @bind-Value="_registerModel.Email" class="form-input" placeholder="email@example.com" />
                            <ValidationMessage For="() => _registerModel.Email" />
                        </div>

                        <div class="form-group">
                            <label class="form-label">Пароль</label>
                            <InputText @bind-Value="_registerModel.Password" type="password" class="form-input" placeholder="Минимум 6 символов" />
                            <ValidationMessage For="() => _registerModel.Password" />
                        </div>

                        <button type="submit" class="btn-primary" style="width: 100%;" disabled="@_isSubmitting">
                            @(_isSubmitting ? "Регистрация..." : "Зарегистрироваться")
                        </button>
                    </EditForm>
                }
            </div>
        </div>
    }
    else
    {
        <!-- Profile Card -->
        <div class="profile-card" style="margin-top: -8rem; position: relative; z-index: 10;">
            <div class="profile-avatar-large">
                @GetInitial(_user?.Name)
            </div>
            
            <div class="profile-info">
                <h1>@_user?.Name</h1>
                <p class="email">@_user?.Email</p>
                <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                    <a href="/settings" style="color: var(--accent); font-weight: 600; text-decoration: none;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 14px; height: 14px; vertical-align: middle; margin-right: 0.25rem;">
                            <circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
                        </svg>
                        Настройки
                    </a>
                    <a href="#" @onclick="HandleLogout" @onclick:preventDefault>Выйти из аккаунта</a>
                </div>
            </div>

            <button class="profile-logout" title="Выйти" @onclick="HandleLogout">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
            </button>
        </div>

        <!-- Favorites Section -->
        <section style="margin-bottom: 4rem; margin-top: 3rem;">
            <h2 class="section-title">Избранное</h2>
            
            @if (_isLoadingFavorites)
            {
                <div class="loading">Загрузка избранного...</div>
            }
            else if (_favorites != null && _favorites.Any())
            {
                <div class="carousel-container">
                    <div class="carousel-wrapper">
                        @foreach (var movie in _favorites)
                        {
                            <a href="/movie/@movie.Id" class="carousel-item">
                                <img src="@GetPosterUrl(movie.PosterUrl)" alt="@movie.Title">
                                <div class="carousel-overlay"></div>
                                <div style="position: absolute; bottom: 1rem; left: 0; right: 0; text-align: center;">
                                    <p style="font-weight: 600; font-size: 0.9rem;">@movie.Title</p>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }
            else
            {
                <p style="color: var(--text-muted);">У вас пока нет избранных фильмов</p>
            }
        </section>

        <!-- Subscription Section -->
        <section class="subscription-section">
            @if (_user?.HasSubscription == true && _user.Subscription != null)
            {
                <div style="margin-bottom: 1rem;">
                    <span class="premium-badge" style="position: static; display: inline-block; font-size: 0.8rem; padding: 0.4rem 1rem;">
                        @_user.Subscription.Name.ToUpper()
                    </span>
                </div>
                <h2>Ваша подписка: @_user.Subscription.Name</h2>
                <p>Действует до: @_user.Subscription.EndDate?.ToString("dd.MM.yyyy")</p>
                <a href="/subscription" class="btn-secondary" style="background-color: transparent; border: 2px solid var(--text-light); color: var(--text-light);">Изменить подписку</a>
            }
            else
            {
                <h2>Получите доступ ко всем фильмам</h2>
                <p>Оформите подписку и смотрите без ограничений</p>
                <a href="/subscription" class="btn-secondary">Выбрать подписку</a>
            }
        </section>
    }
</div>

@code {
    private bool _isAuthenticated = false;
    private bool _isLoginMode = true;
    private bool _isSubmitting = false;
    private bool _isLoadingFavorites = false;
    private string? _errorMessage;
    
    private UserResponse? _user;
    private List<MovieResponse>? _favorites;
    
    private LoginModel _loginModel = new();
    private RegisterModel _registerModel = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthState.InitializeAsync();
            _isAuthenticated = AuthState.IsAuthenticated;
            _user = AuthState.CurrentUser;
            
            if (_isAuthenticated)
            {
                if (!string.IsNullOrEmpty(AuthState.Token))
                {
                    try
                    {
                        var freshUser = await ApiService.GetCurrentUserAsync(AuthState.Token);
                        if (freshUser != null)
                        {
                            _user = freshUser;
                            await AuthState.UpdateUserAsync(freshUser);
                        }
                    }
                    catch { }
                }
                await LoadFavorites();
            }
            
            StateHasChanged();
        }
    }

    private async Task HandleLogin()
    {
        _isSubmitting = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var result = await ApiService.LoginAsync(new LoginRequest
            {
                Email = _loginModel.Email,
                Password = _loginModel.Password
            });

            if (result != null)
            {
                await AuthState.LoginAsync(result.User, result.Token);
                _user = result.User;
                _isAuthenticated = true;
                await LoadFavorites();
            }
            else
            {
                _errorMessage = "Неверный email или пароль";
            }
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Не удалось подключиться к серверу";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task HandleRegister()
    {
        _isSubmitting = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var result = await ApiService.RegisterAsync(new RegisterRequest
            {
                Name = _registerModel.Name,
                Email = _registerModel.Email,
                Password = _registerModel.Password
            });

            if (result != null)
            {
                await AuthState.LoginAsync(result.User, result.Token);
                _user = result.User;
                _isAuthenticated = true;
            }
            else
            {
                _errorMessage = "Ошибка регистрации. Возможно, email уже используется.";
            }
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Не удалось подключиться к серверу";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task HandleLogout()
    {
        await AuthState.LogoutAsync();
        _isAuthenticated = false;
        _user = null;
        _favorites = null;
        _loginModel = new();
        _registerModel = new();
        StateHasChanged();
    }

    private async Task LoadFavorites()
    {
        if (!_isAuthenticated || string.IsNullOrEmpty(AuthState.Token)) return;
        
        _isLoadingFavorites = true;
        StateHasChanged();
        
        try
        {
            _favorites = await ApiService.GetUserFavoritesAsync(AuthState.Token);
        }
        catch
        {
            _favorites = new List<MovieResponse>();
        }
        finally
        {
            _isLoadingFavorites = false;
            StateHasChanged();
        }
    }

    private string GetInitial(string? name)
    {
        if (string.IsNullOrEmpty(name)) return "U";
        return name[0].ToString().ToUpper();
    }

    private string GetPosterUrl(string? posterUrl)
    {
        if (string.IsNullOrEmpty(posterUrl))
            return "/images/no-poster.svg";
        return posterUrl;
    }

    public class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email обязателен")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Некорректный формат email")]
        [System.ComponentModel.DataAnnotations.MaxLength(255, ErrorMessage = "Email слишком длинный")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Пароль обязателен")]
        [System.ComponentModel.DataAnnotations.MaxLength(128, ErrorMessage = "Пароль слишком длинный")]
        public string Password { get; set; } = string.Empty;
    }

    public class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Имя обязательно")]
        [System.ComponentModel.DataAnnotations.MinLength(1, ErrorMessage = "Имя не может быть пустым")]
        [System.ComponentModel.DataAnnotations.MaxLength(100, ErrorMessage = "Имя не может быть длиннее 100 символов")]
        public string Name { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email обязателен")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Некорректный формат email")]
        [System.ComponentModel.DataAnnotations.MaxLength(255, ErrorMessage = "Email слишком длинный")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Пароль обязателен")]
        [System.ComponentModel.DataAnnotations.MinLength(6, ErrorMessage = "Пароль должен быть не менее 6 символов")]
        [System.ComponentModel.DataAnnotations.MaxLength(128, ErrorMessage = "Пароль слишком длинный")]
        public string Password { get; set; } = string.Empty;
    }
}
