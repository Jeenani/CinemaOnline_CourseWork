@page "/search"
@using CinemaServer.DTOs
@using CinemaServer.WebServices
@inject CinemaApiService ApiService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>CINEMA ONLINE - Поиск фильмов</PageTitle>

<div class="container" style="padding-top: 2rem; padding-bottom: 3rem;">
    <h1 class="section-title">Поиск фильмов</h1>

    <!-- Search & Filters -->
    <div class="search-filters">
        <div class="search-box">
            <input type="text" 
                   @bind="_searchQuery" 
                   @bind:event="oninput"
                   @onkeyup="HandleSearchKeyUp"
                   class="form-input search-input" 
                   placeholder="Поиск по названию..." />
            <button class="search-submit" @onclick="ApplyFilters">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.35-4.35"></path>
                </svg>
            </button>
        </div>

        <div class="filters-row">
            <div class="filter-group">
                <label class="form-label">Жанр</label>
                <select @bind="_selectedGenreId" class="form-select">
                    <option value="">Все жанры</option>
                    @if (_genres != null)
                    {
                        @foreach (var genre in _genres)
                        {
                            <option value="@genre.Id">@genre.DisplayName</option>
                        }
                    }
                </select>
            </div>

            <div class="filter-group">
                <label class="form-label">Год от</label>
                <select @bind="_yearFrom" class="form-select">
                    <option value="">Любой</option>
                    @for (int year = DateTime.Now.Year; year >= 1950; year--)
                    {
                        <option value="@year">@year</option>
                    }
                </select>
            </div>

            <div class="filter-group">
                <label class="form-label">Год до</label>
                <select @bind="_yearTo" class="form-select">
                    <option value="">Любой</option>
                    @for (int year = DateTime.Now.Year; year >= 1950; year--)
                    {
                        <option value="@year">@year</option>
                    }
                </select>
            </div>

            <div class="filter-group">
                <label class="form-label">Страна</label>
                <select @bind="_selectedCountry" class="form-select">
                    <option value="">Все страны</option>
                    @if (_countries != null)
                    {
                        @foreach (var country in _countries)
                        {
                            <option value="@country">@country</option>
                        }
                    }
                </select>
            </div>

            <div class="filter-group">
                <label class="form-label">Мин. рейтинг</label>
                <select @bind="_minRating" class="form-select">
                    <option value="">Любой</option>
                    <option value="4">4+ ★</option>
                    <option value="3">3+ ★</option>
                    <option value="2">2+ ★</option>
                </select>
            </div>

            <div class="filter-group filter-actions">
                <label class="form-label">&nbsp;</label>
                <div class="filter-buttons">
                    <button class="btn-primary" @onclick="ApplyFilters">Найти</button>
                    <button class="btn-reset" @onclick="ResetFilters">Сброс</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Results Info -->
    @if (_response != null && !_isLoading)
    {
        <div class="results-info">
            <span>Найдено: @_response.TotalCount фильмов</span>
        </div>
    }

    <!-- Error -->
    @if (_error != null)
    {
        <div class="error-message">@_error</div>
    }

    <!-- Loading -->
    @if (_isLoading)
    {
        <div class="loading">Загрузка фильмов...</div>
    }
    else if (_movies != null && _movies.Any())
    {
        <!-- Movies Grid -->
        <div class="movies-grid">
            @foreach (var movie in _movies)
            {
                <a href="/movie/@movie.Id" class="movie-card">
                    <div class="movie-card-poster">
                        @if (movie.NeedSubscription)
                        {
                            <div class="premium-badge">PREMIUM</div>
                        }
                        <img src="@GetPosterUrl(movie.PosterUrl)" alt="@movie.Title">
                    </div>
                    <div class="movie-card-body">
                        <h3 class="movie-title">@movie.Title</h3>
                        <div class="movie-meta">
                            @if (movie.ReleaseYear.HasValue)
                            {
                                <span>@movie.ReleaseYear</span>
                            }
                            @if (!string.IsNullOrEmpty(movie.Country))
                            {
                                <span>• @movie.Country</span>
                            }
                        </div>
                        <div class="movie-genres">
                            @foreach (var genre in movie.Genres.Take(2))
                            {
                                <span class="genre-badge">@genre</span>
                            }
                        </div>
                        <div class="movie-rating">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var starClass = i <= Math.Round(movie.AverageRating) ? "star" : "star empty";
                                <svg class="@starClass" viewBox="0 0 24 24">
                                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                </svg>
                            }
                            <span class="rating-value">@movie.AverageRating.ToString("0.0")</span>
                        </div>
                    </div>
                </a>
            }
        </div>

        <!-- Pagination -->
        @if (_response != null && _response.TotalPages > 1)
        {
            <div class="pagination">
                <button class="pagination-btn" disabled="@(_currentPage <= 1)" @onclick="PrevPage">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="15 18 9 12 15 6"></polyline>
                    </svg>
                </button>

                @for (int i = Math.Max(1, _currentPage - 2); i <= Math.Min(_response.TotalPages, _currentPage + 2); i++)
                {
                    var pageNum = i;
                    <button class="pagination-btn @(pageNum == _currentPage ? "active" : "")" @onclick="() => GoToPage(pageNum)">
                        @pageNum
                    </button>
                }

                <button class="pagination-btn" disabled="@(_currentPage >= _response.TotalPages)" @onclick="NextPage">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                </button>
            </div>
        }
    }
    else if (!_isLoading)
    {
        <div class="no-results">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
            </svg>
            <p>Фильмы не найдены</p>
            <p class="no-results-hint">Попробуйте изменить параметры поиска</p>
        </div>
    }
</div>

@code {
    private List<MovieResponse>? _movies;
    private PagedResponse<MovieResponse>? _response;
    private List<GenreResponse>? _genres;
    private List<string>? _countries;
    private bool _isLoading = true;
    private string? _error;

    private string _searchQuery = "";
    private string _selectedGenreId = "";
    private string _yearFrom = "";
    private string _yearTo = "";
    private string _selectedCountry = "";
    private string _minRating = "";
    private int _currentPage = 1;
    private const int PageSize = 12;

    protected override async Task OnInitializedAsync()
    {
        await LoadFiltersData();
        await LoadMovies();
    }

    private async Task LoadFiltersData()
    {
        try
        {
            var genresTask = ApiService.GetGenresAsync();
            var countriesTask = ApiService.GetCountriesAsync();
            await Task.WhenAll(genresTask, countriesTask);
            _genres = await genresTask;
            _countries = await countriesTask;
        }
        catch { }
    }

    private async Task LoadMovies()
    {
        _isLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var request = new MovieSearchRequest
            {
                Search = string.IsNullOrWhiteSpace(_searchQuery) ? null : _searchQuery,
                GenreId = string.IsNullOrEmpty(_selectedGenreId) ? null : long.Parse(_selectedGenreId),
                YearFrom = string.IsNullOrEmpty(_yearFrom) ? null : int.Parse(_yearFrom),
                YearTo = string.IsNullOrEmpty(_yearTo) ? null : int.Parse(_yearTo),
                Country = string.IsNullOrEmpty(_selectedCountry) ? null : _selectedCountry,
                MinRating = string.IsNullOrEmpty(_minRating) ? null : decimal.Parse(_minRating),
                SortBy = "rating",
                SortDescending = true,
                Page = _currentPage,
                PageSize = PageSize
            };

            _response = await ApiService.GetMoviesAsync(request);
            _movies = _response?.Items;
        }
        catch (HttpRequestException ex)
        {
            _error = $"Не удалось подключиться к серверу. ({ex.Message})";
        }
        catch (Exception ex)
        {
            _error = $"Ошибка загрузки: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ApplyFilters()
    {
        _currentPage = 1;
        await LoadMovies();
    }

    private async Task ResetFilters()
    {
        _searchQuery = "";
        _selectedGenreId = "";
        _yearFrom = "";
        _yearTo = "";
        _selectedCountry = "";
        _minRating = "";
        _currentPage = 1;
        await LoadMovies();
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await ApplyFilters();
    }

    private async Task GoToPage(int page)
    {
        _currentPage = page;
        await LoadMovies();
    }

    private async Task PrevPage()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
            await LoadMovies();
        }
    }

    private async Task NextPage()
    {
        if (_response != null && _currentPage < _response.TotalPages)
        {
            _currentPage++;
            await LoadMovies();
        }
    }

    private string GetPosterUrl(string? posterUrl)
    {
        if (string.IsNullOrEmpty(posterUrl))
            return "/images/no-poster.svg";
        return posterUrl;
    }
}
