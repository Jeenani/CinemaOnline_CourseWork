    // ========== VK VIDEO ==========

    private void ExtractVkUrl()
    {
        _vkExtractError = null;
        if (string.IsNullOrWhiteSpace(_vkIframeCode))
        {
            _vkExtractError = "Вставьте код iframe";
            return;
        }

        var code = _vkIframeCode.Trim();

        // If user pasted a direct URL already
        if (code.StartsWith("https://vkvideo.ru/video_ext.php") || code.StartsWith("https://vk.com/video_ext.php"))
        {
            _mf.VkVideoUrl = code;
            _showVkPicker = false;
            _vkIframeCode = "";
            return;
        }

        // Extract src from <iframe src="..."
        var srcIdx = code.IndexOf("src=\"", StringComparison.OrdinalIgnoreCase);
        if (srcIdx < 0)
        {
            srcIdx = code.IndexOf("src='", StringComparison.OrdinalIgnoreCase);
            if (srcIdx >= 0)
            {
                srcIdx += 5;
                var endIdx = code.IndexOf("'", srcIdx, StringComparison.Ordinal);
                if (endIdx > srcIdx)
                {
                    _mf.VkVideoUrl = code[srcIdx..endIdx];
                    _showVkPicker = false;
                    _vkIframeCode = "";
                    return;
                }
            }
            _vkExtractError = "Не удалось найти src в iframe коде. Вставьте полный <iframe> код с VK Видео.";
            return;
        }

        srcIdx += 5;
        var endQuote = code.IndexOf('\"', srcIdx);
        if (endQuote <= srcIdx)
        {
            _vkExtractError = "Не удалось извлечь URL из iframe";
            return;
        }

        _mf.VkVideoUrl = code[srcIdx..endQuote];
        _showVkPicker = false;
        _vkIframeCode = "";
    }

