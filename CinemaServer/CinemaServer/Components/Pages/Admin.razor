@page "/admin"
@using CinemaServer.DTOs
@using CinemaServer.WebServices
@inject CinemaApiService ApiService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>CINEMA ONLINE - Админ-панель</PageTitle>

<div class="container" style="padding-top: 2rem; padding-bottom: 3rem;">
    @if (!_ready)
    {
        <div class="loading">Загрузка...</div>
    }
    else if (!_isAdmin)
    {
        <div class="error-message" style="text-align: center; margin-top: 4rem;">
            <h2>Доступ запрещён</h2>
            <p style="margin-top: 1rem;">Только для администраторов</p>
            <a href="/" class="btn-primary" style="margin-top: 1rem; display: inline-block;">На главную</a>
        </div>
    }
    else
    {
        <h1 style="margin-bottom: 1.5rem; font-size: 1.75rem;">Админ-панель</h1>

        <!-- Tabs -->
        <div class="admin-tabs">
            <button class="admin-tab @(_tab == 0 ? "active" : "")" @onclick="() => SwitchTab(0)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="admin-tab-icon"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
                Статистика
            </button>
            <button class="admin-tab @(_tab == 1 ? "active" : "")" @onclick="() => SwitchTab(1)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="admin-tab-icon"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><path d="m7 2 0 20"/><path d="m17 2 0 20"/><path d="M2 12h20"/><path d="M2 7h5"/><path d="M2 17h5"/><path d="M17 17h5"/><path d="M17 7h5"/></svg>
                Фильмы
            </button>
            <button class="admin-tab @(_tab == 2 ? "active" : "")" @onclick="() => SwitchTab(2)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="admin-tab-icon"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                Пользователи
            </button>
            <button class="admin-tab @(_tab == 3 ? "active" : "")" @onclick="() => SwitchTab(3)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="admin-tab-icon"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                Контент
            </button>
        </div>

        @if (_msg != null)
        {
            <div class="@(_msgOk ? "success-message" : "error-message")" style="margin-bottom: 1rem;">@_msg</div>
        }

        <!-- TAB 0: Stats -->
        @if (_tab == 0 && _stats != null)
        {
            <div class="admin-stats-grid">
                <div class="admin-stat-card"><span class="stat-num">@_stats.MoviesCount</span><span>Фильмов</span></div>
                <div class="admin-stat-card"><span class="stat-num">@_stats.UsersCount</span><span>Пользователей</span></div>
                <div class="admin-stat-card"><span class="stat-num">@_stats.ActiveSubscriptions</span><span>Подписок</span></div>
                <div class="admin-stat-card"><span class="stat-num">@_stats.CommentsCount</span><span>Комментариев</span></div>
                <div class="admin-stat-card"><span class="stat-num">@_stats.GenresCount</span><span>Жанров</span></div>
                <div class="admin-stat-card"><span class="stat-num">@_stats.CollectionsCount</span><span>Коллекций</span></div>
                <div class="admin-stat-card"><span class="stat-num">@_stats.TotalViews</span><span>Просмотров</span></div>
                <div class="admin-stat-card"><span class="stat-num">@_stats.PaidPayments</span><span>Платежей</span></div>
            </div>
        }

        <!-- TAB 1: Movies -->
        @if (_tab == 1)
        {
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                <h2 style="font-size: 1.25rem;">Фильмы (@(_movies?.Count ?? 0))</h2>
                <button class="btn-primary" style="padding: 0.5rem 1.25rem;" @onclick="ShowAddMovie">+ Добавить</button>
            </div>

            @if (_showMovieForm)
            {
                <div class="admin-form-card">
                    <h3>@(_editMovieId.HasValue ? "Редактирование" : "Новый фильм")</h3>
                    <div class="admin-form-grid">
                        <div class="form-group"><label class="form-label">Название *</label>
                            <input class="form-input" @bind="_mf.Title" /></div>
                        <div class="form-group"><label class="form-label">Год</label>
                            <input type="number" class="form-input" @bind="_mf.ReleaseYear" /></div>
                        <div class="form-group"><label class="form-label">Страна</label>
                            <input class="form-input" @bind="_mf.Country" /></div>
                        <div class="form-group"><label class="form-label">Режиссёр</label>
                            <input class="form-input" @bind="_mf.Director" /></div>
                        <div class="form-group"><label class="form-label">Продолжительность (мин)</label>
                            <input type="number" class="form-input" @bind="_mf.DurationMinutes" /></div>
                        <div class="form-group"><label class="form-label">URL видео (fallback)</label>
                            <input class="form-input" @bind="_mf.VideoUrl" placeholder="https://example.com/video.mp4" /></div>
                    </div>

                    <!-- VK Video -->
                    <div class="form-group" style="margin-bottom: 1rem;">
                        <label class="form-label">VK Видео</label>
                        <div style="display: flex; gap: 0.5rem; align-items: flex-start;">
                            <input class="form-input" @bind="_mf.VkVideoUrl" placeholder="https://vkvideo.ru/video_ext.php?oid=...&id=...&hash=..." style="flex: 1;" />
                            <button type="button" class="btn-primary" style="padding: 0.5rem 0.75rem; white-space: nowrap;" @onclick="() => _showVkPicker = true">Извлечь из iframe</button>
                        </div>
                        @if (!string.IsNullOrEmpty(_mf.VkVideoUrl))
                        {
                            <div style="margin-top: 0.75rem; border: 1px solid var(--border-color); border-radius: 0.5rem; overflow: hidden; position: relative; padding-bottom: 56.25%; height: 0;">
                                <iframe src="@_mf.VkVideoUrl"
                                        style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; background: #000;"
                                        allowfullscreen="true"
                                        allow="autoplay; encrypted-media; fullscreen; picture-in-picture">
                                </iframe>
                            </div>
                        }
                    </div>

                    <div class="form-group"><label class="form-label">Описание</label>
                        <textarea class="form-input" rows="3" @bind="_mf.Description"></textarea></div>

                    <div class="admin-form-grid">
                        <div class="form-group">
                            <label class="form-label">URL постера</label>
                            <input class="form-input" @bind="_mf.PosterUrl" placeholder="https://... или загрузите файл" />
                            <InputFile OnChange="HandlePosterUpload" style="margin-top: 0.5rem; font-size: 0.85rem;" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">URL баннера</label>
                            <input class="form-input" @bind="_mf.BannerUrl" placeholder="https://... или загрузите файл" />
                            <InputFile OnChange="HandleBannerUpload" style="margin-top: 0.5rem; font-size: 0.85rem;" />
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_mf.PosterUrl))
                    {
                        <div style="margin-bottom: 1rem;">
                            <img src="@GetFullImageUrl(_mf.PosterUrl)" alt="poster" style="height: 120px; border-radius: 0.5rem; object-fit: cover;" />
                        </div>
                    }

                    <div class="form-group">
                        <label class="form-label">Жанры</label>
                        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
                            @if (_genres != null)
                            {
                                @foreach (var g in _genres)
                                {
                                    var selected = _mf.GenreIds.Contains(g.Id);
                                    <button type="button"
                                            class="genre-badge @(selected ? "selected" : "")"
                                            style="cursor: pointer; @(selected ? "background: var(--accent); color: var(--bg-dark);" : "")"
                                            @onclick="() => ToggleGenre(g.Id)">
                                        @g.DisplayName
                                    </button>
                                }
                            }
                        </div>
                    </div>

                    <label style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; cursor: pointer;">
                        <input type="checkbox" @bind="_mf.NeedSubscription" style="width: 18px; height: 18px; accent-color: var(--accent);" />
                        <span>Требуется подписка (Premium)</span>
                    </label>

                    <div style="display: flex; gap: 0.75rem;">
                        <button class="btn-primary" @onclick="SaveMovie" disabled="@_saving">@(_saving ? "Сохранение..." : "Сохранить")</button>
                        <button class="btn-secondary" style="background: transparent; border: 1px solid var(--border-color); padding: 0.5rem 1.25rem; border-radius: 0.375rem; cursor: pointer; color: var(--text-light);" @onclick="() => _showMovieForm = false">Отмена</button>
                    </div>
                </div>
            }

            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead><tr><th>Постер</th><th>Название</th><th>Год</th><th>Жанры</th><th>Рейтинг</th><th>Статус</th><th>Действия</th></tr></thead>
                    <tbody>
                    @if (_movies != null)
                    {
                        @foreach (var m in _movies)
                        {
                            <tr>
                                <td><img src="@GetFullImageUrl(m.PosterUrl)" style="width: 50px; height: 70px; object-fit: cover; border-radius: 0.25rem;" /></td>
                                <td style="font-weight: 600;">@m.Title</td>
                                <td>@m.ReleaseYear</td>
                                <td><span style="font-size: 0.8rem; color: var(--text-muted);">@string.Join(", ", m.Genres.Take(3))</span></td>
                                <td>
                                    <span style="color: var(--accent);">@m.AverageRating.ToString("0.0")</span>
                                </td>
                                <td>
                                    @if (m.NeedSubscription) { <span class="premium-badge" style="position: static; font-size: 0.6rem;">PREMIUM</span> }
                                    @if (!m.IsPublished) { <span style="color: #ff6b6b; font-size: 0.75rem;">Скрыт</span> }
                                </td>
                                <td>
                                    <div style="display: flex; gap: 0.25rem;">
                                        <button class="admin-action-btn" title="Редактировать" @onclick="() => EditMovie(m)">
                                            @IconEdit
                                        </button>
                                        <button class="admin-action-btn admin-action-btn--danger" title="Удалить" @onclick="() => DeleteMovie(m.Id)">
                                            @IconTrash
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        }

        <!-- TAB 2: Users -->
        @if (_tab == 2)
        {
            <h2 style="font-size: 1.25rem; margin-bottom: 1rem;">Пользователи (@(_users?.Count ?? 0))</h2>
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead><tr><th>Имя</th><th>Email</th><th>Роль</th><th>Подписка</th><th>Регистрация</th><th>Действия</th></tr></thead>
                    <tbody>
                    @if (_users != null)
                    {
                        @foreach (var u in _users)
                        {
                            <tr>
                                <td style="font-weight: 600;">@u.Name</td>
                                <td>@u.Email</td>
                                <td>
                                    <select value="@u.Role" @onchange="(e) => ChangeRole(u.Id, e.Value?.ToString())"
                                            style="background: var(--card-bg); color: var(--text-light); border: 1px solid var(--border-color); border-radius: 0.25rem; padding: 0.25rem; font-size: 0.8rem;">
                                        <option value="user">user</option>
                                        <option value="admin">admin</option>
                                    </select>
                                </td>
                                <td>
                                    @if (u.HasSubscription && u.SubscriptionName != null)
                                    {
                                        <span style="color: var(--accent); font-weight: 600;">@u.SubscriptionName</span>
                                        <br/><span style="font-size: 0.75rem; color: var(--text-muted);">до @u.SubscriptionEnd?.ToString("dd.MM.yy")</span>
                                    }
                                    else { <span style="color: var(--text-muted);">—</span> }
                                </td>
                                <td style="font-size: 0.8rem; color: var(--text-muted);">@u.CreatedAt?.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <button class="admin-action-btn admin-action-btn--danger" title="Удалить" @onclick="() => DeleteUser(u.Id)">
                                        @IconTrash
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        }

        <!-- TAB 3: Content -->
        @if (_tab == 3)
        {
            <div class="admin-tabs" style="margin-bottom: 1rem;">
                <button class="admin-tab @(_subTab == 0 ? "active" : "")" @onclick="() => _subTab = 0">Жанры</button>
                <button class="admin-tab @(_subTab == 1 ? "active" : "")" @onclick="() => _subTab = 1">Коллекции</button>
                <button class="admin-tab @(_subTab == 2 ? "active" : "")" @onclick="() => _subTab = 2">Комментарии</button>
            </div>

            @if (_subTab == 0)
            {
                <div style="display: flex; gap: 0.75rem; margin-bottom: 1rem; align-items: flex-end; flex-wrap: wrap;">
                    <div class="form-group" style="margin: 0;">
                        <label class="form-label">Название жанра</label>
                        <input class="form-input" @bind="_genreDisplay" placeholder="Боевик" style="width: 200px;" />
                    </div>
                    <button class="btn-primary" style="padding: 0.5rem 1rem; height: fit-content;" @onclick="AddGenre">Добавить</button>
                </div>
                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead><tr><th>Код</th><th>Название</th><th>Действия</th></tr></thead>
                        <tbody>
                        @if (_genres != null)
                        {
                            @foreach (var g in _genres)
                            {
                                <tr>
                                    <td style="color: var(--text-muted);">@g.Name</td>
                                    <td style="font-weight: 600;">@g.DisplayName</td>
                                    <td>
                                        <button class="admin-action-btn admin-action-btn--danger" title="Удалить" @onclick="() => DeleteGenre(g.Id)">
                                            @IconTrash
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            }

            @if (_subTab == 1)
            {
                <div style="display: flex; gap: 0.75rem; margin-bottom: 1rem; align-items: flex-end; flex-wrap: wrap;">
                    <div class="form-group" style="margin: 0;"><label class="form-label">Название</label>
                        <input class="form-input" @bind="_colName" style="width: 200px;" /></div>
                    <div class="form-group" style="margin: 0;"><label class="form-label">Описание</label>
                        <input class="form-input" @bind="_colDesc" style="width: 200px;" /></div>
                    <label style="display: flex; align-items: center; gap: 0.25rem; cursor: pointer; padding-bottom: 0.25rem;">
                        <input type="checkbox" @bind="_colFeatured" style="accent-color: var(--accent);" /> Избранная
                    </label>
                    <button class="btn-primary" style="padding: 0.5rem 1rem; height: fit-content;" @onclick="AddCollection">Добавить</button>
                </div>
                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead><tr><th>Название</th><th>Описание</th><th>Избранная</th><th>Фильмов</th><th>Действия</th></tr></thead>
                        <tbody>
                        @if (_collections != null)
                        {
                            @foreach (var c in _collections)
                            {
                                <tr>
                                    <td style="font-weight: 600;">@c.Name</td>
                                    <td>@c.Description</td>
                                    <td>
                                        @if (c.IsFeatured)
                                        {
                                            <span style="color: var(--accent);">Да</span>
                                        }
                                        else
                                        {
                                            <span style="color: var(--text-muted);">—</span>
                                        }
                                    </td>
                                    <td>@c.MoviesCount</td>
                                    <td>
                                        <button class="admin-action-btn admin-action-btn--danger" title="Удалить" @onclick="() => DeleteCollection(c.Id)">
                                            @IconTrash
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            }

            @if (_subTab == 2)
            {
                <h3 style="font-size: 1.1rem; margin-bottom: 1rem;">Последние комментарии</h3>
                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead><tr><th>Пользователь</th><th>Фильм</th><th>Комментарий</th><th>Статус</th><th>Действия</th></tr></thead>
                        <tbody>
                        @if (_comments != null)
                        {
                            @foreach (var c in _comments)
                            {
                                <tr style="@(!c.IsVisible ? "opacity: 0.5;" : "")">
                                    <td style="font-weight: 600;">@c.UserName</td>
                                    <td>@c.MovieTitle</td>
                                    <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@c.Content</td>
                                    <td>
                                        @if (c.IsVisible)
                                        {
                                            <span style="color: var(--accent);">Виден</span>
                                        }
                                        else
                                        {
                                            <span style="color: #ff6b6b;">Скрыт</span>
                                        }
                                    </td>
                                    <td>
                                        <div style="display: flex; gap: 0.25rem;">
                                            <button class="admin-action-btn" title="@(c.IsVisible ? "Скрыть" : "Показать")" @onclick="() => ToggleComment(c.Id)">
                                                @IconEye
                                            </button>
                                            <button class="admin-action-btn admin-action-btn--danger" title="Удалить" @onclick="() => DeleteComment(c.Id)">
                                                @IconTrash
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            }
        }
    }
</div>

@* VK Video iframe extractor modal *@
@if (_showVkPicker)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,.7); z-index: 1000; display: flex; align-items: center; justify-content: center;" @onclick="() => _showVkPicker = false">
        <div style="background: var(--card-bg); border-radius: 0.75rem; padding: 1.5rem; max-width: 600px; width: 90%; max-height: 90vh; overflow-y: auto;" @onclick:stopPropagation>
            <h3 style="margin-bottom: 1rem;">Извлечь ссылку из VK Видео</h3>
            <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem;">
                Откройте видео на <a href="https://vkvideo.ru" target="_blank" style="color: var(--accent);">vkvideo.ru</a>, 
                нажмите «Поделиться» ? «Встроить», скопируйте код <code>&lt;iframe&gt;</code> и вставьте ниже:
            </p>
            <textarea class="form-input" rows="5" placeholder='<iframe src="https://vkvideo.ru/video_ext.php?oid=...&id=...&hash=..." ...></iframe>'
                      @bind="_vkIframeCode" @bind:event="oninput"></textarea>
            @if (_vkExtractError != null)
            {
                <p style="color: #ff6b6b; font-size: 0.85rem; margin-top: 0.5rem;">@_vkExtractError</p>
            }
            <div style="display: flex; gap: 0.75rem; margin-top: 1rem;">
                <button class="btn-primary" @onclick="ExtractVkUrl">Извлечь и вставить</button>
                <button class="btn-secondary" style="background: transparent; border: 1px solid var(--border-color); padding: 0.5rem 1.25rem; border-radius: 0.375rem; cursor: pointer; color: var(--text-light);" @onclick="() => _showVkPicker = false">Отмена</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _ready, _isAdmin, _saving;
    private int _tab, _subTab;
    private string? _msg; private bool _msgOk;
    private string Token => AuthState.Token ?? "";

    // SVG icon fragments
    private static readonly RenderFragment IconEdit = @<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="admin-icon"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>;
    private static readonly RenderFragment IconTrash = @<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="admin-icon"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>;
    private static readonly RenderFragment IconEye = @<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="admin-icon"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>;

    // Data
    private AdminStats? _stats;
    private List<AdminMovie>? _movies;
    private List<AdminUser>? _users;
    private List<GenreResponse>? _genres;
    private List<AdminCollection>? _collections;
    private List<AdminComment>? _comments;

    // Movie form
    private bool _showMovieForm;
    private long? _editMovieId;
    private MovieFormModel _mf = new();

    // Genre form
    private string _genreDisplay = "";

    // Collection form
    private string _colName = "", _colDesc = "";
    private bool _colFeatured;

    // VK Video picker
    private bool _showVkPicker;
    private string _vkIframeCode = "";
    private string? _vkExtractError;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await AuthState.InitializeAsync();
        _isAdmin = AuthState.IsAuthenticated && AuthState.CurrentUser?.Role == "admin";
        _ready = true;
        if (_isAdmin) await LoadTab(0);
        StateHasChanged();
    }

    private async Task SwitchTab(int tab) { _tab = tab; _msg = null; await LoadTab(tab); }

    private async Task LoadTab(int tab)
    {
        try
        {
            switch (tab)
            {
                case 0:
                    _stats = await ApiService.AdminGetAsync<AdminStats>("/api/admin/stats", Token);
                    break;
                case 1:
                    _movies = await ApiService.AdminGetAsync<List<AdminMovie>>("/api/admin/movies", Token);
                    _genres ??= await ApiService.GetGenresAsync();
                    break;
                case 2:
                    _users = await ApiService.AdminGetAsync<List<AdminUser>>("/api/admin/users", Token);
                    break;
                case 3:
                    _genres ??= await ApiService.GetGenresAsync();
                    _collections = await ApiService.AdminGetAsync<List<AdminCollection>>("/api/admin/collections", Token);
                    _comments = await ApiService.AdminGetAsync<List<AdminComment>>("/api/admin/comments", Token);
                    break;
            }
        }
        catch (Exception ex) { ShowMsg($"Ошибка: {ex.Message}", false); }
        StateHasChanged();
    }

    // ========== MOVIES ==========

    private void ShowAddMovie() { _editMovieId = null; _mf = new(); _showMovieForm = true; }

    private void EditMovie(AdminMovie m)
    {
        _editMovieId = m.Id;
        _mf = new MovieFormModel
        {
            Title = m.Title, ReleaseYear = m.ReleaseYear, Country = m.Country,
            Director = m.Director, PosterUrl = m.PosterUrl, BannerUrl = m.BannerUrl,
            VkVideoUrl = m.VkVideoUrl, VideoUrl = m.VideoUrl ?? string.Empty,
            Description = m.Description, DurationMinutes = m.DurationMinutes,
            NeedSubscription = m.NeedSubscription, GenreIds = new(m.GenreIds)
        };
        _showMovieForm = true;
    }

    private async Task SaveMovie()
    {
        if (string.IsNullOrWhiteSpace(_mf.Title)) { ShowMsg("Укажите название", false); return; }
        _saving = true; StateHasChanged();
        try
        {
            bool ok;
            if (_editMovieId.HasValue)
            {
                ok = await ApiService.AdminPutAsync($"/api/movies/{_editMovieId}", new
                {
                    _mf.Title, _mf.Description, _mf.ReleaseYear, _mf.DurationMinutes,
                    _mf.VideoUrl, _mf.VkVideoUrl, _mf.PosterUrl, _mf.BannerUrl, _mf.Country, _mf.Director,
                    _mf.NeedSubscription, _mf.GenreIds
                }, Token);
            }
            else
            {
                if (string.IsNullOrWhiteSpace(_mf.VideoUrl)) _mf.VideoUrl = "https://example.com/video.mp4";
                ok = await ApiService.AdminPostAsync("/api/movies", new
                {
                    _mf.Title, _mf.Description, _mf.ReleaseYear, _mf.DurationMinutes,
                    _mf.VideoUrl, _mf.VkVideoUrl, _mf.PosterUrl, _mf.BannerUrl, _mf.Country, _mf.Director,
                    _mf.NeedSubscription, _mf.GenreIds
                }, Token);
            }
            if (ok) { _showMovieForm = false; ShowMsg("Фильм сохранён", true); await LoadTab(1); }
            else ShowMsg("Ошибка сохранения", false);
        }
        catch (Exception ex) { ShowMsg(ex.Message, false); }
        finally { _saving = false; StateHasChanged(); }
    }

