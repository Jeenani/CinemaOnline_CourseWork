    private async Task HandlePosterUpload(InputFileChangeEventArgs e)
    {
        var url = await UploadFile(e.File);
        if (url != null) _mf.PosterUrl = url;
    }

    private async Task HandleBannerUpload(InputFileChangeEventArgs e)
    {
        var url = await UploadFile(e.File);
        if (url != null) _mf.BannerUrl = url;
    }

    private async Task<string?> UploadFile(IBrowserFile file)
    {
        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(5 * 1024 * 1024).CopyToAsync(ms);
            var url = await ApiService.AdminUploadAsync("/api/admin/upload", ms.ToArray(), file.Name, Token);
            if (url != null) ShowMsg("Файл загружен", true);
            else ShowMsg("Ошибка загрузки файла", false);
            return url;
        }
        catch { ShowMsg("Файл слишком большой (макс 5 МБ)", false); return null; }
    }

