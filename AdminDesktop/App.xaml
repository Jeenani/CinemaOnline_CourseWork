<Application x:Class="AdminDesktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:AdminDesktop.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibility x:Key="BoolVis"/>
            <conv:InverseBoolToVisibility x:Key="InvBoolVis"/>
            <conv:NullToVisibility x:Key="NullVis"/>
            <conv:EqualConverter x:Key="EqConv"/>
        </ResourceDictionary>
    </Application.Resources>
    </Application>
