<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

<ScrollView
    android:id="@+id/scroll_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include layout="@layout/layout_header" />

        <!-- Top bar with back button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/accent_pink"
                android:contentDescription="back"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/back_label"
                android:textColor="@color/accent_pink"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/bona_nova_sc"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Poster -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="280dp">

            <ImageView
                android:id="@+id/iv_poster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="poster"
                android:scaleType="centerCrop" />

            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_card_rounded" />
        </FrameLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/bona_nova_sc"
                android:layout_marginBottom="4dp" />

            <!-- Subtitle (year) -->
            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_inactive"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <!-- Rating stars row -->
            <LinearLayout
                android:id="@+id/ll_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp" />

            <!-- Action buttons (auth-dependent) -->
            <LinearLayout
                android:id="@+id/ll_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/btn_watch"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/bg_button_accent"
                    android:text="@string/watch_button"
                    android:textColor="@color/background"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/bona_nova_sc"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_favorite"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/bg_button_outlined"
                    android:text="@string/favorite_button"
                    android:textColor="@color/accent_pink"
                    android:textSize="14sp"
                    android:fontFamily="@font/bona_nova_sc"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_share"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/bg_button_outlined"
                    android:text="@string/share_button"
                    android:textColor="@color/accent_pink"
                    android:textSize="14sp"
                    android:fontFamily="@font/bona_nova_sc"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Login to watch button (for non-auth) -->
            <TextView
                android:id="@+id/btn_login_to_watch"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center"
                android:background="@drawable/bg_button_accent"
                android:text="@string/login_to_watch"
                android:textColor="@color/background"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/bona_nova_sc"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

            <!-- Subscription required block (for auth without subscription) -->
            <LinearLayout
                android:id="@+id/ll_subscription_required"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/subscription_required"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/btn_subscribe_to_watch"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:background="@drawable/bg_button_accent"
                    android:text="@string/subscribe_to_watch"
                    android:textColor="@color/background"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/bona_nova_sc"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Video Player -->
            <FrameLayout
                android:id="@+id/ll_player"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <WebView
                    android:id="@+id/wv_player"
                    android:layout_width="match_parent"
                    android:layout_height="220dp" />
            </FrameLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/card_border"
                android:layout_marginBottom="16dp" />

            <!-- Info card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <!-- Genre -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="@string/film_detail_genre"
                        android:textColor="@color/text_inactive"
                        android:textSize="14sp"
                        android:fontFamily="@font/bona_nova_sc" />

                    <TextView
                        android:id="@+id/tv_genre"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Year -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="@string/year_label"
                        android:textColor="@color/text_inactive"
                        android:textSize="14sp"
                        android:fontFamily="@font/bona_nova_sc" />

                    <TextView
                        android:id="@+id/tv_year"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Director -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="@string/director_label"
                        android:textColor="@color/text_inactive"
                        android:textSize="14sp"
                        android:fontFamily="@font/bona_nova_sc" />

                    <TextView
                        android:id="@+id/tv_director"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Duration -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="@string/duration_label"
                        android:textColor="@color/text_inactive"
                        android:textSize="14sp"
                        android:fontFamily="@font/bona_nova_sc" />

                    <TextView
                        android:id="@+id/tv_duration"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Description -->
            <TextView
                android:id="@+id/tv_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="24dp" />

            <!-- Related movies section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/related_movies_title"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/bona_nova_sc"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_related"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:layout_marginBottom="24dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/card_border"
                android:layout_marginBottom="20dp" />

            <!-- Comments title -->
            <TextView
                android:id="@+id/tv_comments_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/comments_title"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/bona_nova_sc"
                android:layout_marginBottom="16dp" />

            <!-- Comment input (auth-dependent) -->
            <LinearLayout
                android:id="@+id/ll_comment_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <!-- User avatar -->
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="12dp">

                        <View
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_avatar" />

                        <TextView
                            android:id="@+id/tv_comment_avatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:textColor="@color/background"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <!-- Rating stars for comment -->
                    <LinearLayout
                        android:id="@+id/ll_comment_stars"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </LinearLayout>

                <EditText
                    android:id="@+id/et_comment"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_input"
                    android:hint="@string/write_something"
                    android:textColorHint="@color/input_hint"
                    android:textColor="@color/input_text"
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/btn_send_comment"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@drawable/bg_button_accent"
                    android:text="@string/send_comment"
                    android:textColor="@color/background"
                    android:textSize="14sp"
                    android:fontFamily="@font/bona_nova_sc"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Comments list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_comments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>

<!-- Fullscreen video overlay -->
<FrameLayout
    android:id="@+id/fl_fullscreen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone"
    android:background="@android:color/black" />

</FrameLayout>
